Bootstrap: docker
From: nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04

%labels
    Author shshemi-ai-bot
    Description Unsloth LoRA fine-tuning container (CUDA 12.8, PyTorch cu128, uv)

%environment
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
    export HF_HOME=/output/hf
    export PATH="/root/.local/bin:$PATH"

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    export TZ=Europe/London
    ln -fs /usr/share/zoneinfo/$TZ /etc/localtime
    echo $TZ > /etc/timezone

    apt-get update
    apt-get install -y --no-install-recommends \
        tzdata \
        ca-certificates \
        curl \
        git \
        build-essential
    rm -rf /var/lib/apt/lists/*

    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"

    uv python install 3.11

    mkdir -p /workspace /output/hf /data

%files
    unsloth/train.py /workspace/unsloth/train.py
    unsloth/llm_sft_qwen3_5-800M.yaml /workspace/unsloth/config.yaml
    scripts/download_data.py /workspace/scripts/download_data.py

%post
    export PATH="/root/.local/bin:$PATH"
    uv run --python 3.11 /workspace/scripts/download_data.py chat
    cp /workspace/output/splits/train.jsonl /data/train.jsonl
    cp /workspace/output/splits/valid.jsonl /data/valid.jsonl
    cp /workspace/output/splits/test.jsonl /data/test.jsonl
    rm -rf /workspace/output

%runscript
    cd /output
    exec uv run --python 3.11 --script /workspace/unsloth/train.py -- --config /workspace/unsloth/config.yaml
